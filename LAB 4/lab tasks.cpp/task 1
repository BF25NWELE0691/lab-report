// Program: Display Day Name using Switch

#include <iostream>
using namespace std;

int main()
{
    int day;  // variable jisme user day number enter karega

    cout << "Enter day number (1-7): ";
    cin >> day;  // user se input liya

    // switch statement day ki value check karega
    switch(day)
    {
        case 1:
            cout << "Monday";
            break;

        case 2:
            cout << "Tuesday";
            break;

        case 3:
            cout << "Wednesday";
            break;

        case 4:
            cout << "Thursday";
            break;

        case 5:
            cout << "Friday";
            break;

        case 6:
            cout << "Saturday";
            break;

        case 7:
            cout << "Sunday";
            break;

        default:  // agar 1-7 ke ilawa koi number ho
            cout << "Invalid day number";
    }

    return 0; // program end
}
